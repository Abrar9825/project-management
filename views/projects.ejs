<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects | Project Control System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/design-system.css">
</head>
<body class="bg-gray-50 min-h-screen">

    <%- include('partials/nav', { activePage: 'projects' }) %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Page Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
                <h1 class="ds-page-title">Projects</h1>
                <p class="ds-page-subtitle">Overview of all active projects</p>
            </div>
            <a href="/add-project" class="ds-btn ds-btn-md ds-btn-primary admin-only">
                <svg class="ds-icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                New Project
            </a>
        </div>

        <!-- Stats Overview -->
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8" id="statsOverview">
            <div class="ds-stat-card text-center">
                <p class="ds-stat-value text-gray-900" id="stat-total">0</p>
                <p class="ds-stat-label mt-1">Total Projects</p>
            </div>
            <div class="ds-stat-card text-center">
                <p class="ds-stat-value text-emerald-600" id="stat-healthy">0</p>
                <p class="ds-stat-label mt-1">On Track</p>
            </div>
            <div class="ds-stat-card text-center">
                <p class="ds-stat-value text-blue-600" id="stat-active">0</p>
                <p class="ds-stat-label mt-1">In Progress</p>
            </div>
            <div class="ds-stat-card text-center">
                <p class="ds-stat-value text-amber-600" id="stat-atrisk">0</p>
                <p class="ds-stat-label mt-1">At Risk</p>
            </div>
            <div class="ds-stat-card text-center col-span-2 lg:col-span-1">
                <p class="ds-stat-value text-red-600" id="stat-critical">0</p>
                <p class="ds-stat-label mt-1">Critical</p>
            </div>
        </div>

        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" id="projectsGrid">
            <div class="flex items-center justify-center py-12 col-span-full">
                <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-teal-600"></div>
                <span class="ml-3 text-gray-600">Loading projects...</span>
            </div>
        </div>

    </main>

    <!-- API Script -->
    <script src="/js/api.js"></script>
    <script>
        let projects = [];
        let currentUser = null;
        
        const cardGradients = ['card-gradient-1', 'card-gradient-2', 'card-gradient-3', 'card-gradient-4', 'card-gradient-5', 'card-gradient-6', 'card-gradient-7', 'card-gradient-8'];

        const projectStatusConfig = {
            'active': { dot: 'bg-blue-500', label: 'In Progress', textColor: 'text-blue-600' },
            'completed': { dot: 'bg-emerald-500', label: 'Completed', textColor: 'text-emerald-600' },
            'on-hold': { dot: 'bg-amber-500', label: 'On Hold', textColor: 'text-amber-600' },
            'cancelled': { dot: 'bg-red-500', label: 'Cancelled', textColor: 'text-red-600' }
        };

        const healthConfig = {
            'healthy': { dot: 'bg-emerald-500', label: 'On Track', textColor: 'text-emerald-600' },
            'at-risk': { dot: 'bg-amber-500', label: 'At Risk', textColor: 'text-amber-600' },
            'critical': { dot: 'bg-red-500', label: 'Critical', textColor: 'text-red-600' }
        };

        const projectPriorityConfig = {
            'critical': { bg: 'bg-red-100', text: 'text-red-700' },
            'high': { bg: 'bg-orange-100', text: 'text-orange-700' },
            'medium': { bg: 'bg-blue-100', text: 'text-blue-700' },
            'low': { bg: 'bg-gray-100', text: 'text-gray-600' }
        };

        // Load projects from API
        async function loadProjects() {
            try {
                const result = await api.getProjects();
                if (result.success) {
                    let allProjects = result.data || [];
                    // Subadmin: only show projects where they are a team member
                    if (currentUser.role === 'subadmin') {
                        const myId = String(currentUser._id || currentUser.id);
                        allProjects = allProjects.filter(p => {
                            return (p.team || []).some(t => String(t.user?._id || t.user) === myId);
                        });
                    }
                    projects = allProjects;
                    renderProjects();
                    updateStats();
                } else {
                    document.getElementById('projectsGrid').innerHTML = `
                        <div class="col-span-full text-center py-12">
                            <p class="text-red-600">Failed to load projects: ${result.error}</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Load projects error:', error);
                document.getElementById('projectsGrid').innerHTML = `
                    <div class="col-span-full text-center py-12">
                        <p class="text-red-600">Connection failed. Is server running?</p>
                    </div>
                `;
            }
        }

        // Update stats
        function updateStats() {
            document.getElementById('stat-total').textContent = projects.length;
            document.getElementById('stat-healthy').textContent = projects.filter(p => p.health === 'healthy').length;
            document.getElementById('stat-active').textContent = projects.filter(p => p.status === 'active').length;
            document.getElementById('stat-atrisk').textContent = projects.filter(p => p.health === 'at-risk').length;
            document.getElementById('stat-critical').textContent = projects.filter(p => p.health === 'critical').length;
        }

        // Render projects
        function renderProjects() {
            const container = document.getElementById('projectsGrid');
            
            if (projects.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full text-center py-12">
                        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-2">No projects yet</h3>
                        <p class="text-gray-500 mb-4">Create your first project to get started</p>
                        <a href="/add-project" class="ds-btn ds-btn-sm ds-btn-primary admin-only">
                            <svg class="ds-icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            Create Project
                        </a>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = projects.map((project, index) => {
                const health = healthConfig[project.health] || healthConfig['healthy'];
                const priority = projectPriorityConfig[project.priority] || projectPriorityConfig['medium'];
                const gradient = cardGradients[index % cardGradients.length];
                const progress = project.progress || 0;
                const teamSize = project.team?.length || 0;
                const currentStage = project.stages?.find(s => s.status === 'in-progress')?.name || 'Not Started';
                
                return `
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all cursor-pointer group" 
                         onclick="window.location.href='/project-detail?id=${project._id}'">
                        <!-- Gradient Header -->
                        <div class="${gradient} p-5 group-hover:opacity-90 transition-opacity">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="text-base font-bold text-white">${project.name}</h3>
                                    <p class="text-white/80 text-xs mt-1">${project.clientDetails?.name || project.client || 'No Client'}</p>
                                </div>
                                <span class="px-2 py-0.5 text-xs font-semibold rounded-md bg-white/20 text-white capitalize backdrop-blur-sm">
                                    ${project.priority || 'medium'}
                                </span>
                            </div>
                        </div>
                        
                        <!-- Content -->
                        <div class="p-5">
                            <!-- Status & Stage -->
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <span class="w-2 h-2 rounded-full ${health.dot} animate-pulse"></span>
                                    <span class="text-xs font-medium ${health.textColor}">${health.label}</span>
                                </div>
                                <span class="text-xs text-gray-500">Stage: <span class="font-medium text-gray-700">${currentStage}</span></span>
                            </div>
                            
                            <!-- Progress Bar -->
                            <div class="mb-4">
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-gray-500">Progress</span>
                                    <span class="font-semibold text-gray-700">${progress}%</span>
                                </div>
                                <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
                                    <div class="h-full ${gradient} rounded-full transition-all" style="width: ${progress}%"></div>
                                </div>
                            </div>
                            
                            <!-- Footer Info -->
                            <div class="flex items-center justify-between pt-3 pb-3 border-t border-gray-100">
                                <div class="flex items-center gap-2">
                                    <div class="flex -space-x-2">
                                        ${Array(Math.min(teamSize, 3)).fill(0).map((_, i) => `
                                            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-slate-300 to-slate-400 border border-white flex items-center justify-center text-[10px] font-medium text-white">
                                                ${String.fromCharCode(65 + i)}
                                            </div>
                                        `).join('')}
                                        ${teamSize > 3 ? `
                                            <div class="w-6 h-6 rounded-full bg-gray-200 border border-white flex items-center justify-center text-[10px] font-medium text-gray-600">
                                                +${teamSize - 3}
                                            </div>
                                        ` : ''}
                                    </div>
                                    <span class="text-xs text-gray-400">${teamSize} members</span>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="flex gap-2 pt-2" onclick="event.stopPropagation();">
                                <a href="/client-portal?id=${project._id}" 
                                   class="flex-1 ds-btn ds-btn-xs ds-btn-primary justify-center">
                                    <svg class="ds-icon-xs" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg> Client Portal
                                </a>
                                <a href="/document-center?id=${project._id}" 
                                   class="flex-1 ds-btn ds-btn-xs ds-btn-outline justify-center">
                                    <svg class="ds-icon-xs" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> Doc Center
                                </a>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // Init
        async function init() {
            if (!api.isLoggedIn()) {
                window.location.href = '/login';
                return;
            }
            
            currentUser = api.getUser();
            if (!currentUser || !currentUser.name) {
                window.location.href = '/login';
                return;
            }
            
            // Developers should only see My Work
            if (currentUser.role === 'developer') {
                window.location.href = '/my-work';
                return;
            }
            
            document.getElementById('userName').textContent = currentUser.name;
            document.getElementById('userInitials').textContent = currentUser.name.split(' ').map(n => n[0]).join('').substring(0, 2);
            
            if (currentUser.role !== 'admin') {
                document.querySelectorAll('.admin-only').forEach(el => el.style.display = 'none');
            }
            
            await loadProjects();
        }

        init();
    </script>
</body>
</html>
