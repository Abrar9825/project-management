        function switchTab(tab) {
            var contents = document.querySelectorAll('.tab-content');
            for (var i = 0; i < contents.length; i++) contents[i].classList.add('hidden');
            var tabs = document.querySelectorAll('.portal-tab');
            for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('tab-active');
            document.getElementById('tab-' + tab).classList.remove('hidden');
            document.querySelector('[data-tab="' + tab + '"]').classList.add('tab-active');
            // Clear badge for this tab
            setBadge(tab, 0);
            // Mark as seen based on current count
            if (tab === 'documents') {
                var docCards = document.getElementById('clientDocsGrid')?.querySelectorAll('.card-hover') || [];
                markTabSeen('documents', docCards.length);
            } else if (tab === 'meetings') {
                var mtgCards = document.getElementById('meetingsGrid')?.querySelectorAll('.card-hover') || [];
                markTabSeen('meetings', mtgCards.length);
            }
        }

        function showToast(message, type) {
            type = type || 'info';
            var toast = document.createElement('div');
            var colors = { info: 'bg-blue-600', success: 'bg-emerald-600', error: 'bg-red-600' };
            toast.className = 'fixed bottom-4 right-4 ' + colors[type] + ' text-white px-6 py-3 rounded-xl shadow-2xl z-50 font-medium text-sm';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(function() { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.3s'; setTimeout(function() { toast.remove(); }, 300); }, 3000);
        }

        async function markAssetUploaded(stageId, assetId) {
            try {
                await api.fetch('/projects/' + projectId + '/stages/' + stageId + '/asset-requests/' + assetId, 'PUT', { status: 'received' });
                showToast('Asset marked as uploaded!', 'success');
                await loadClientView();
            } catch(e) {
                showToast('Error updating asset status', 'error');
            }
        }

        async function uploadAssetFile(stageId, assetId, input) {
            if (!input.files || !input.files[0]) return;
            var file = input.files[0];
            if (file.size > 50 * 1024 * 1024) { showToast('File too large (max 50MB)', 'error'); return; }
            var formData = new FormData();
            formData.append('file', file);
            try {
                var token = localStorage.getItem('token');
                var res = await fetch('/api/projects/' + projectId + '/stages/' + stageId + '/asset-requests/' + assetId, {
                    method: 'PUT',
                    headers: { 'Authorization': 'Bearer ' + token },
                    body: formData
                });
                var data = await res.json();
                if (data.success) {
                    showToast('File uploaded successfully!', 'success');
                    await loadClientView();
                } else {
                    showToast(data.error || 'Upload failed', 'error');
                }
            } catch(e) {
                showToast('Error uploading file', 'error');
            }
        }

        // ==================== CLIENT TASKS ====================
        var portalTasks = [];

        async function loadClientPortalTasks() {
            try {
                var token = localStorage.getItem('token');
                var res = await fetch('/api/client-tasks/' + projectId, {
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }
                });
                var data = await res.json();
                if (data.success) {
                    portalTasks = data.data || [];
                    renderClientPortalTasks();
                }
            } catch(e) {
                document.getElementById('clientTaskTimeline').innerHTML = '<div class="text-center text-red-400 py-8">Error loading tasks</div>';
            }
        }

        function renderClientPortalTasks() {
            var container = document.getElementById('clientTaskTimeline');
            var pending = portalTasks.filter(function(t) { return t.status === 'pending'; }).length;
            var inProgress = portalTasks.filter(function(t) { return t.status === 'in-progress'; }).length;
            var completed = portalTasks.filter(function(t) { return t.status === 'completed'; }).length;

            document.getElementById('cpPendingCount').textContent = pending + ' Pending';
            document.getElementById('cpProgressCount').textContent = inProgress + ' Active';
            document.getElementById('cpCompletedCount').textContent = completed + ' Done';

            if (portalTasks.length === 0) {
                container.innerHTML = '<div class="text-center py-12"><div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3"><svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><p class="text-gray-400 font-medium">No tasks yet</p></div>';
                renderClientTimeline();
                return;
            }

            var statusCfg = {
                pending: { bg: 'bg-amber-50', text: 'text-amber-700', dot: 'bg-amber-400', label: 'Pending' },
                'in-progress': { bg: 'bg-blue-50', text: 'text-blue-700', dot: 'bg-blue-400', label: 'In Progress' },
                completed: { bg: 'bg-emerald-50', text: 'text-emerald-700', dot: 'bg-emerald-400', label: 'Completed' }
            };

            container.innerHTML = portalTasks.map(function(task, idx) {
                var st = statusCfg[task.status] || statusCfg.pending;
                var isFromAdmin = task.assignedBy === 'admin';
                var shortDesc = task.description.length > 55 ? task.description.substring(0, 55) + '...' : task.description;

                var actionBtn = '';
                if (isFromAdmin) {
                    if (task.status === 'pending') {
                        actionBtn = '<button onclick="event.stopPropagation();clientStartTask(\'' + task._id + '\')" class="px-3 py-1.5 bg-brand-600 text-white text-[11px] font-semibold rounded-lg hover:bg-brand-700 transition-all">Start</button>';
                    } else if (task.status === 'in-progress') {
                        actionBtn = '<button onclick="event.stopPropagation();clientCompleteTask(\'' + task._id + '\')" class="px-3 py-1.5 bg-emerald-600 text-white text-[11px] font-semibold rounded-lg hover:bg-emerald-700 transition-all">Complete</button>';
                    }
                }

                return '<div class="p-4 hover:bg-gray-50 transition-all cursor-pointer" onclick="openClientTaskDetail(' + idx + ')">' +
                    '<div class="flex items-start justify-between gap-3">' +
                        '<div class="flex gap-3 flex-1 min-w-0">' +
                            '<div class="w-2 h-2 rounded-full mt-2 flex-shrink-0 ' + st.dot + '"></div>' +
                            '<div class="flex-1 min-w-0">' +
                                '<div class="flex items-center gap-2 mb-1 flex-wrap">' +
                                    '<span class="px-2 py-0.5 text-[10px] font-bold rounded-full ' + (isFromAdmin ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700') + '">' + (isFromAdmin ? 'From Team' : 'Your Request') + '</span>' +
                                    '<span class="px-2 py-0.5 text-[10px] font-medium rounded-full bg-gray-100 text-gray-600">' + task.phase + '</span>' +
                                '</div>' +
                                '<p class="text-sm text-gray-900 truncate">' + shortDesc + '</p>' +
                            '</div>' +
                        '</div>' +
                        '<div class="flex items-center gap-2 flex-shrink-0" onclick="event.stopPropagation()">' +
                            '<span class="px-2 py-0.5 text-[10px] font-medium rounded-md ' + st.bg + ' ' + st.text + '">' + st.label + '</span>' +
                            actionBtn +
                        '</div>' +
                    '</div>' +
                '</div>';
            }).join('');

            renderClientTimeline();
        }

        function renderClientTimeline() {
            var container = document.getElementById('clientActivityTimeline');
            if (portalTasks.length === 0) {
                container.innerHTML = '<div class="text-center text-gray-400 py-8 text-sm">No activity yet</div>';
                return;
            }
            var events = [];
            portalTasks.forEach(function(task) {
                var isAdmin = task.assignedBy === 'admin';
                var color = isAdmin ? 'blue' : 'orange';
                var shortDesc = task.description.length > 40 ? task.description.substring(0, 40) + '...' : task.description;
                events.push({ date: new Date(task.createdAt), type: 'assigned', label: isAdmin ? 'Team assigned' : 'You requested', desc: shortDesc, color: color });
                if (task.startedAt) {
                    events.push({ date: new Date(task.startedAt), type: 'started', label: 'Started', desc: shortDesc, color: color });
                }
                if (task.completedAt) {
                    var dur = Math.ceil((new Date(task.completedAt) - new Date(task.createdAt)) / (1000 * 60 * 60 * 24));
                    events.push({ date: new Date(task.completedAt), type: 'completed', label: 'Done in ' + dur + 'd', desc: shortDesc, color: color });
                }
            });
            events.sort(function(a, b) { return b.date - a.date; });

            var colorMap = {
                blue: { dot: 'bg-blue-500', ring: 'ring-blue-200', bg: 'bg-blue-50' },
                orange: { dot: 'bg-orange-500', ring: 'ring-orange-200', bg: 'bg-orange-50' }
            };

            var html = '<div class="relative pl-5">';
            html += '<div class="absolute left-[13px] top-2 bottom-2 w-0.5 bg-gray-200"></div>';
            events.forEach(function(ev) {
                var c = colorMap[ev.color];
                var dateStr = ev.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                var timeStr = ev.date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                var dotIcon = ev.type === 'completed' ? '✓' : ev.type === 'started' ? '►' : '';
                var dotSize = ev.type === 'assigned' ? 'w-2.5 h-2.5' : 'w-5 h-5';
                var dotMargin = ev.type === 'assigned' ? '-ml-[12px]' : '-ml-[17px]';

                html += '<div class="relative flex items-start gap-3 pb-5">' +
                    '<div class="relative z-10 ' + dotSize + ' rounded-full ' + c.dot + ' flex items-center justify-center flex-shrink-0 text-white ring-2 ' + c.ring + ' ' + dotMargin + ' mt-1.5">' +
                        (dotIcon ? '<span class="text-[8px] font-bold">' + dotIcon + '</span>' : '') +
                    '</div>' +
                    '<div class="flex-1 min-w-0 ' + c.bg + ' rounded-lg px-3 py-2">' +
                        '<p class="text-xs font-semibold text-gray-800 leading-tight">' + ev.label + '</p>' +
                        '<p class="text-[11px] text-gray-600 mt-0.5 truncate" title="' + ev.desc.replace(/"/g, '&quot;') + '">' + ev.desc + '</p>' +
                        '<p class="text-[10px] text-gray-400 mt-1">' + dateStr + ' · ' + timeStr + '</p>' +
                    '</div>' +
                '</div>';
            });
            html += '</div>';
            container.innerHTML = html;
        }

        function openClientTaskDetail(idx) {
            var task = portalTasks[idx];
            if (!task) return;
            var isFromAdmin = task.assignedBy === 'admin';
            var badge = document.getElementById('ctModalBadge');
            badge.textContent = isFromAdmin ? 'From Team' : 'Your Request';
            badge.className = 'px-2 py-0.5 text-[10px] font-bold rounded-full ' + (isFromAdmin ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700');
            document.getElementById('ctModalPhase').textContent = task.phase;
            document.getElementById('ctModalBody').textContent = task.description;
            var ts = '';
            ts += '<p class="text-xs text-gray-400">Assigned: ' + new Date(task.createdAt).toLocaleString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) + '</p>';
            if (task.startedAt) ts += '<p class="text-xs text-blue-500">Started: ' + new Date(task.startedAt).toLocaleString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) + '</p>';
            if (task.completedAt) {
                var dur = Math.ceil((new Date(task.completedAt) - new Date(task.createdAt)) / (1000 * 60 * 60 * 24));
                ts += '<p class="text-xs text-emerald-600">Completed: ' + new Date(task.completedAt).toLocaleString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) + ' (' + dur + ' days)</p>';
            }
            document.getElementById('ctModalTimestamps').innerHTML = ts;
            var modal = document.getElementById('clientTaskModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }

        function closeClientTaskModal() {
            var modal = document.getElementById('clientTaskModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = '';
        }

        async function submitClientRequest() {
            var desc = document.getElementById('clientRequestInput').value.trim();
            if (!desc) { showToast('Please type what you need', 'error'); return; }

            try {
                var user = JSON.parse(localStorage.getItem('user') || '{}');
                var token = localStorage.getItem('token');
                var res = await fetch('/api/client-tasks/' + projectId, {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phase: 'Requirement', description: desc, assignedBy: 'client', assignedByName: user.name || 'Client' })
                });
                var data = await res.json();
                if (data.success) {
                    document.getElementById('clientRequestInput').value = '';
                    showToast('Request submitted!', 'success');
                    await loadClientPortalTasks();
                } else {
                    showToast(data.error || 'Failed', 'error');
                }
            } catch(e) {
                showToast('Error submitting request', 'error');
            }
        }

        async function clientStartTask(id) {
            try {
                var token = localStorage.getItem('token');
                var res = await fetch('/api/client-tasks/' + id + '/start', {
                    method: 'PUT',
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }
                });
                var data = await res.json();
                if (data.success) { showToast('Task started!', 'success'); await loadClientPortalTasks(); }
                else { showToast(data.error || 'Failed', 'error'); }
            } catch(e) { showToast('Error', 'error'); }
        }

        async function clientCompleteTask(id) {
            try {
                var token = localStorage.getItem('token');
                var res = await fetch('/api/client-tasks/' + id + '/complete', {
                    method: 'PUT',
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }
                });
                var data = await res.json();
                if (data.success) { showToast('Task completed!', 'success'); await loadClientPortalTasks(); }
                else { showToast(data.error || 'Failed', 'error'); }
            } catch(e) { showToast('Error', 'error'); }
        }

        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/login';
        }

        init();
    </script>
</body>
</html>
