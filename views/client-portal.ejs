                html += '</div></div>';
            }

            // ===== WHOSE SIDE IS IT? - SIMPLE STAGE LIST =====
            html += '<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-6">' +
                '<div class="px-6 py-4 border-b border-gray-100">' +
                    '<h3 class="font-bold text-gray-900 text-lg">Current Work Status</h3>' +
                    '<p class="text-xs text-gray-500 mt-0.5">Which side is each stage currently waiting on</p>' +
                '</div>' +
                '<div class="divide-y divide-gray-100">';

            d.stageOverview.sort(function(a, b) { return (a.order || 0) - (b.order || 0); });
            d.stageOverview.forEach(function(s) {
                var isCompleted = s.status === 'completed';
                var isPending = s.status === 'pending';
                var color = getHolderColor(s.currentHolder);
                var icon = stageIcons[s.name] || s.icon || '📌';

                html += '<div class="flex items-center gap-4 px-5 py-4 hover:bg-gray-50 transition-colors">';

                // Stage icon + name
                html += '<div class="flex items-center gap-3 flex-1 min-w-0">' +
                    '<span class="text-xl flex-shrink-0">' + icon + '</span>' +
                    '<div class="min-w-0">' +
                        '<p class="font-semibold text-gray-900 text-sm">' + s.name + '</p>';
                // Show reason if active
                if (!isCompleted && !isPending && s.holderReason) {
                    html += '<p class="text-xs text-gray-500 truncate">' + s.holderReason + '</p>';
                }
                html += '</div></div>';

                // Holder badge
                if (isCompleted) {
                    html += '<span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold rounded-full bg-emerald-100 text-emerald-700 flex-shrink-0">' +
                        '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>' +
