                        color.label + '</span>';
                }

                // Wait time
                if (!isCompleted && !isPending && s.waitingDays > 0) {
                    html += '<span class="text-xs font-semibold ' + color.text + ' ml-2 flex-shrink-0">' + formatWaitDays(s.waitingDays) + '</span>';
                }

                html += '</div>';
            });

            html += '</div></div>';

            // ===== TIMELINE =====
            if (d.timeline && d.timeline.length > 0) {
                html += '<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">' +
