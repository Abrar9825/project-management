        function formatWaitDays(days) {
            if (days <= 0) return 'Just now';
            if (days === 1) return '1 day';
            if (days < 30) return days + ' days';
            var months = Math.floor(days / 30);
            var rem = days % 30;
            return months + 'mo ' + rem + 'd';
        }

        function getHolderColor(holder) {
            if (holder === 'agency') return { bg: 'bg-blue-100', text: 'text-blue-700', border: 'border-blue-200', gradient: 'from-blue-500 to-blue-700', dot: 'bg-blue-500', label: 'Agency (Our Team)' };
            if (holder === 'client') return { bg: 'bg-amber-100', text: 'text-amber-700', border: 'border-amber-200', gradient: 'from-amber-500 to-amber-700', dot: 'bg-amber-500', label: 'Client (Your Side)' };
            if (holder === 'testing') return { bg: 'bg-violet-100', text: 'text-violet-700', border: 'border-violet-200', gradient: 'from-violet-500 to-violet-700', dot: 'bg-violet-500', label: 'QA Testing' };
            if (holder === 'review') return { bg: 'bg-indigo-100', text: 'text-indigo-700', border: 'border-indigo-200', gradient: 'from-indigo-500 to-indigo-700', dot: 'bg-indigo-500', label: 'Under Review' };
            if (holder === 'completed') return { bg: 'bg-emerald-100', text: 'text-emerald-700', border: 'border-emerald-200', gradient: 'from-emerald-500 to-emerald-700', dot: 'bg-emerald-500', label: 'Completed ✅' };
            if (holder === 'none') return { bg: 'bg-gray-100', text: 'text-gray-500', border: 'border-gray-200', gradient: 'from-gray-400 to-gray-600', dot: 'bg-gray-400', label: 'Not Started' };
            return { bg: 'bg-gray-100', text: 'text-gray-500', border: 'border-gray-200', gradient: 'from-gray-400 to-gray-600', dot: 'bg-gray-400', label: 'Not Set' };
